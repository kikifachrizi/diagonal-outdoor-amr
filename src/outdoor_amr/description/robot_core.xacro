<?xml version="1.0"?>
<robot name="sentinel_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>
    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>
    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>
    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>
    <material name="green_tosca">
        <color rgba="0.0 0.7 0.6 1"/>
    </material>

    <material name="pink">
        <color rgba="1.0 0.4 0.7 1"/>
    </material>

    <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
    </material>

    <!-- BASE LINK -->

    <link name="base_link">
    </link>

    <!-- BASE FOOTPRINT     -->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>

    <!-- CHASSIS LINK  -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.426 0.30 0.1"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.18" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.06" y="0.6" z="0.3">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_box>
    </link>
    <gazebo reference="chassis">
        <material>
            Gazebo/White
        </material>
    </gazebo>

    <!-- LEFT WHEEL -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.0 0.180 0.063" rpy="0 0 0"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <mesh filename="package://outdoor_amr/meshes/left_wheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0.0125 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.0635" length="0.024"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.024" radius="0.0635">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="left_wheel">
        <material>
            Gazebo/Blue
        </material>
    </gazebo>

    <!-- RIGHT WHEEL -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.0 -0.180 0.063" rpy="0 0 0"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <origin rpy="0 0 3.14159"/>
            <geometry>
                <mesh filename="package://outdoor_amr/meshes/right_wheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 -0.0125 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.0635" length="0.024"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.024" radius="0.0635">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="right_wheel">
        <material>
            Gazebo/Blue
        </material>
    </gazebo>

    <!-- CASTER WHEEL REAR LINK -->
    <joint name="rear_caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="rear_caster_wheel"/>
        <origin xyz="0.116 0.0 0.052"/>
    </joint>
    <link name="rear_caster_wheel">
        <visual>
            <geometry>
                <mesh filename="package://outdoor_amr/meshes/front_caster.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0.038 0.0 -0.002" rpy="1.5708 0 0"/>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>
    <gazebo reference="rear_caster_wheel">
        <material>
            Gazebo/Black
        </material>
    </gazebo>

    <!-- CASTER WHEEL BACK LINK  -->
    <joint name="back_caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="back_caster_wheel"/>
        <origin xyz="-0.116 0.0 0.052" rpy="0 0 3.14"/>
    </joint>
    <link name="back_caster_wheel">
        <visual>
            <geometry>
                <mesh filename="package://outdoor_amr/meshes/back_caster.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0.038 0.0 -0.002" rpy="1.5708 0 0"/>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>
    <gazebo reference="back_caster_wheel">
        <material>
            Gazebo/Black
        </material>
        <mu1 value="0.001"></mu1>
        <mu2 value="0.001"></mu2>
    </gazebo>

</robot>
